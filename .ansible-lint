profile: min

mock_roles:
  - jenkins

warn_list:
  - fqcn[action-core]
  - fqcn[action]
  - name[casing]

skip_list:
  - yaml[line-length]
  - name[missing]
  - jinja[spacing]
  - var-naming[no-role-prefix]
  - risky-file-permissions
  - command-instead-of-module
  - risky-shell-pipe
  - command-instead-of-shell
  - no-changed-when
  - internal-error

exclude_paths:
  - .git
  - roles/jenkins/files
