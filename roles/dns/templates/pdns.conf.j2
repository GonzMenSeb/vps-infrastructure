launch=gmysql
gmysql-host=pdns-db
gmysql-port=3306
gmysql-dbname=pdns
gmysql-user=pdns
gmysql-password={{ vault_pdns_db_password }}

api=yes
api-key={{ vault_pdns_api_key }}
webserver=yes
webserver-address=0.0.0.0
webserver-port=8081
webserver-allow-from=0.0.0.0/0,::/0

local-address=0.0.0.0
local-port=53

default-soa-content={{ pdns_soa }}
