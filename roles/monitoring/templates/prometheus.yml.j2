global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: "{{ domain.split('.')[0] }}"
    env: prod

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          host: vps

# Local scrape targets are collected by Alloy and shipped via remote_write.
# Cross-VPS metrics from the Jenkins host arrive via remote_write on the
# prom-push endpoint.
