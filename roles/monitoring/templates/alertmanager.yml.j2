# Alertmanager config rendered by Ansible.
# Set `vault_alertmanager_slack_webhook` in vault.yml to a real Slack webhook
# URL and re-run `ansible-playbook playbook.yml` to enable Slack routing.
# Until then, alerts land in the Alertmanager UI via the `default` null receiver.

route:
  receiver: default
  group_by: [alertname, severity]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h
{% if vault_alertmanager_slack_webhook | default('') %}
  routes:
    - match:
        severity: critical
      receiver: slack
{% endif %}

receivers:
  - name: default
    # Null receiver - alerts aggregate in the Alertmanager UI with no external notification.

{% if vault_alertmanager_slack_webhook | default('') %}
  - name: slack
    slack_configs:
      - api_url: "{{ vault_alertmanager_slack_webhook }}"
        channel: "#ops"
        send_resolved: true
        title: "[{{ '{{' }} .Status | toUpper {{ '}}' }}] {{ '{{' }} .CommonLabels.alertname {{ '}}' }}"
        text: "{{ '{{' }} range .Alerts {{ '}}' }}{{ '{{' }} .Annotations.summary {{ '}}' }}\n{{ '{{' }} .Annotations.description {{ '}}' }}\n{{ '{{' }} end {{ '}}' }}"
{% endif %}
