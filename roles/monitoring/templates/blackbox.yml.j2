modules:
  http_any_ok:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: "ip4"
      valid_status_codes: [200, 301, 302, 401]
      fail_if_not_ssl: true
      tls_config:
        insecure_skip_verify: false

  http_2xx:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: "ip4"
      valid_status_codes: [200]
      fail_if_not_ssl: true

  tcp_connect:
    prober: tcp
    timeout: 5s
