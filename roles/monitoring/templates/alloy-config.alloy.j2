// Main VPS observability agent.
// Every metric scrape funnels through prometheus.relabel.drop_noise, which
// strips high-cardinality / low-signal series before they hit Prometheus.
// Adding a new scrape? forward_to = [prometheus.relabel.drop_noise.receiver].

logging {
  level  = "info"
  format = "logfmt"
}

////////////////////////////////////////////////////////////////////////////////
// LOGS — Docker container discovery + tail
////////////////////////////////////////////////////////////////////////////////

discovery.docker "containers" {
  host             = "unix:///var/run/docker.sock"
  refresh_interval = "60s"
}

discovery.relabel "containers" {
  targets = discovery.docker.containers.targets

  // Drop log tailing for observability plane itself — self-referential noise
  // that inflates Loki streams without adding operational value.
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(cadvisor|blackbox-exporter|alloy|promtail|process-exporter|tempo)"
    action        = "drop"
  }

  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
    target_label  = "compose_service"
  }

  rule {
    source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
    target_label  = "compose_project"
  }

  rule {
    source_labels = ["__meta_docker_container_log_stream"]
    target_label  = "stream"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.containers.receiver]
  labels     = { host = "vps" }
}

// JSON parse only runs for services we know emit JSON; plaintext containers
// (nginx/postgres/redis) skip the allocator cost. Parsed fields land in
// structured metadata (Loki 3) so they're queryable without fanning out streams.
loki.process "containers" {
  forward_to = [loki.write.local.receiver]

  stage.match {
    selector = "{compose_service=~\"miplata-api|categorizer-api|llama-server\"}"

    stage.json {
      expressions = {
        level    = "level",
        trace_id = "trace_id",
        span_id  = "span_id",
      }
    }

    stage.structured_metadata {
      values = { level = "", trace_id = "", span_id = "" }
    }
  }
}

////////////////////////////////////////////////////////////////////////////////
// LOGS — journald (system services)
////////////////////////////////////////////////////////////////////////////////

loki.relabel "journal" {
  forward_to = []
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }
}

loki.source.journal "system" {
  forward_to    = [loki.write.local.receiver]
  labels        = { host = "vps", compose_service = "systemd" }
  max_age       = "12h"
  path          = "/var/log/journal"
  relabel_rules = loki.relabel.journal.rules
}

////////////////////////////////////////////////////////////////////////////////
// METRICS — cardinality filter (all scrapes funnel through this)
////////////////////////////////////////////////////////////////////////////////

prometheus.relabel "drop_noise" {
  forward_to = [prometheus.remote_write.local.receiver]

  // Ephemeral Docker interfaces churn series on every container restart.
  rule {
    source_labels = ["__name__", "device"]
    regex         = "node_network_.*;(veth.+|br-.+|docker0|lo|dummy.+)"
    action        = "drop"
  }

  // Non-real filesystems — every container spawns overlay mounts.
  rule {
    source_labels = ["__name__", "fstype"]
    regex         = "node_filesystem_.*;(overlay|tmpfs|squashfs|nsfs|autofs|ramfs|fuse\\..*)"
    action        = "drop"
  }

  rule {
    source_labels = ["__name__", "mountpoint"]
    regex         = "node_filesystem_.*;(/var/lib/docker/.+|/run/.+|/snap/.+)"
    action        = "drop"
  }

  // cAdvisor low-signal families.
  rule {
    source_labels = ["__name__"]
    regex         = "container_(tasks_state|sockets|threads_max)"
    action        = "drop"
  }
  rule {
    source_labels = ["__name__"]
    regex         = "container_blkio_.*"
    action        = "drop"
  }
  // Drop all container_fs_* except usage_bytes and limit_bytes. RE2 has no
  // lookahead, so we enumerate the families to drop explicitly.
  rule {
    source_labels = ["__name__"]
    regex         = "container_fs_(inodes_|io_|read|sector_|write)[a-z_]*"
    action        = "drop"
  }

  // cAdvisor root-cgroup rollups (empty id AND empty name). Scoped to
  // container_* metrics so we don't accidentally drop node_exporter / blackbox
  // metrics which simply don't carry id/name labels.
  rule {
    source_labels = ["__name__", "id", "name"]
    regex         = "container_.+;;"
    action        = "drop"
  }

  // Traefik router-level fan-out — keep service + entrypoint only.
  rule {
    source_labels = ["__name__"]
    regex         = "traefik_router_.*"
    action        = "drop"
  }

  // Go runtime internals — keep go_goroutines, process_*, and heap_inuse only.
  rule {
    source_labels = ["__name__"]
    regex         = "go_(gc_.*|sched_.*|sync_.*|memstats_(mspan_.*|mcache_.*|buck_.*|other_.*|gc_.*|next_gc_.*|last_gc_.*))"
    action        = "drop"
  }

  // Blackbox: non-actionable probe metadata for HTTP probes.
  rule {
    source_labels = ["__name__", "job"]
    regex         = "(probe_ip_addr_hash|probe_ip_protocol|probe_dns_lookup_time_seconds);blackbox"
    action        = "drop"
  }
}

////////////////////////////////////////////////////////////////////////////////
// METRICS — static scrapes
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "alloy_self" {
  targets         = [{"__address__" = "localhost:12345", "job" = "alloy", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "60s"
}

prometheus.scrape "node_exporter" {
  targets         = [{"__address__" = "host.docker.internal:9100", "job" = "node_exporter", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

prometheus.scrape "cadvisor" {
  targets         = [{"__address__" = "cadvisor:8080", "job" = "cadvisor", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

prometheus.scrape "alertmanager" {
  targets         = [{"__address__" = "alertmanager:9093", "job" = "alertmanager", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "60s"
}

prometheus.scrape "traefik" {
  targets         = [{"__address__" = "traefik:8082", "job" = "traefik", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

prometheus.scrape "zot" {
  targets         = [{"__address__" = "zot:5000", "job" = "zot", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "60s"
  basic_auth {
    username = "{{ zot_registry_user }}"
    password = "{{ vault_zot_registry_password }}"
  }
}

prometheus.scrape "postgres_exporter" {
  targets         = [{"__address__" = "postgres-exporter:9187", "job" = "postgres_exporter", "host" = "vps", "service" = "miplata"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

prometheus.scrape "redis_exporter" {
  targets         = [{"__address__" = "redis-exporter:9121", "job" = "redis_exporter", "host" = "vps", "service" = "miplata"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

// miplata-api: kept at 15s because it owns the RED latency histograms
// that the Services dashboard renders at percentile resolution.
prometheus.scrape "miplata_api" {
  targets         = [{"__address__" = "miplata-api:3000", "job" = "miplata_api", "host" = "vps", "service" = "miplata"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "15s"
  metrics_path    = "/metrics"
}

// Self-hosted cascade categorizer: /metrics exposed by prometheus_client.
prometheus.scrape "categorizer_api" {
  targets         = [{"__address__" = "categorizer-api:{{ categorizer_app_port }}", "job" = "categorizer-api", "host" = "vps", "service" = "categorizer"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
  metrics_path    = "/metrics"
}

prometheus.scrape "llama_server" {
  targets         = [{"__address__" = "llama-server:{{ llm_inference_port }}", "job" = "llama-server", "host" = "vps", "service" = "categorizer"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "60s"
  metrics_path    = "/metrics"
}

prometheus.scrape "process_exporter" {
  targets         = [{"__address__" = "process-exporter:9256", "job" = "process_exporter", "host" = "vps"}]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
}

////////////////////////////////////////////////////////////////////////////////
// METRICS — blackbox probes (public endpoints)
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "blackbox_probes" {
  targets = [
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ miplata_host }}",              "instance" = "miplata-web",       "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ miplata_host }}/api/health",   "instance" = "miplata-api",       "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ vaultwarden_host }}/alive",    "instance" = "vaultwarden",       "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ pdns_admin_host }}",           "instance" = "dns-admin",         "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ grafana_host }}/api/health",   "instance" = "grafana",           "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ zot_host }}/v2/",              "instance" = "zot-registry",      "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ traefik_dashboard_host }}",    "instance" = "traefik-dashboard", "job" = "blackbox"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ jenkins_host }}/login",        "instance" = "jenkins",           "job" = "blackbox"},
  ]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
  metrics_path    = "/probe"
  params          = { module = ["http_any_ok"] }
}

prometheus.scrape "blackbox_categorizer_healthz" {
  targets = [
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "https://{{ categorizer_host }}/healthz", "instance" = "categorizer-healthz", "job" = "blackbox"},
  ]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "30s"
  metrics_path    = "/probe"
  params          = { module = ["http_categorizer_bearer"] }
}

prometheus.scrape "blackbox_llama_health" {
  targets = [
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "http://llama-server:{{ llm_inference_port }}/health", "instance" = "llama-server-health", "job" = "blackbox"},
  ]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "60s"
  metrics_path    = "/probe"
  params          = { module = ["http_2xx_plain"] }
}

// TLS cert expiry — tls_connect module on each public host.
prometheus.scrape "blackbox_tls" {
  targets = [
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ miplata_host }}:443",           "instance" = "miplata-tls",            "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ vaultwarden_host }}:443",       "instance" = "vaultwarden-tls",        "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ pdns_admin_host }}:443",        "instance" = "dns-admin-tls",          "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ grafana_host }}:443",           "instance" = "grafana-tls",            "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ zot_host }}:443",               "instance" = "zot-tls",                "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ traefik_dashboard_host }}:443", "instance" = "traefik-dashboard-tls",  "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ jenkins_host }}:443",           "instance" = "jenkins-tls",            "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ categorizer_host }}:443",       "instance" = "categorizer-tls",        "job" = "blackbox_tls"},
    {"__address__" = "blackbox-exporter:9115", "__param_target" = "{{ metabase_host }}:443",          "instance" = "metabase-tls",           "job" = "blackbox_tls"},
  ]
  forward_to      = [prometheus.relabel.drop_noise.receiver]
  scrape_interval = "5m"
  metrics_path    = "/probe"
  params          = { module = ["tls_connect"] }
}

{% if enable_tracing %}
////////////////////////////////////////////////////////////////////////////////
// TRACES — OTLP in, tail-sampling, Tempo out
////////////////////////////////////////////////////////////////////////////////

otelcol.receiver.otlp "apps" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }
  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [otelcol.processor.batch.traces.input]
  }
}

otelcol.processor.batch "traces" {
  timeout             = "2s"
  send_batch_size     = 512
  send_batch_max_size = 1024

  output {
    traces = [otelcol.processor.tail_sampling.policy.input]
  }
}

// Tail sampling: policies OR together. Any match keeps the trace.
// The 1% probabilistic baseline runs last as the default-drop fallthrough.
otelcol.processor.tail_sampling "policy" {
  decision_wait               = "10s"
  num_traces                  = 5000
  expected_new_traces_per_sec = 5

  policy {
    name = "keep-errors"
    type = "status_code"
    status_code {
      status_codes = ["ERROR"]
    }
  }

  policy {
    name = "keep-slow"
    type = "latency"
    latency {
      threshold_ms = 1000
    }
  }

  policy {
    name = "keep-5xx"
    type = "numeric_attribute"
    numeric_attribute {
      key       = "http.response.status_code"
      min_value = 500
      max_value = 599
    }
  }

  policy {
    name = "baseline"
    type = "probabilistic"
    probabilistic {
      sampling_percentage = 1
    }
  }

  output {
    traces = [otelcol.exporter.otlp.tempo.input]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"
    tls {
      insecure = true
    }
  }
}
{% endif %}

////////////////////////////////////////////////////////////////////////////////
// WRITES
////////////////////////////////////////////////////////////////////////////////

prometheus.remote_write "local" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"

    // Queue tuned for a loopback endpoint. Defaults (10k capacity, 50 shards)
    // are sized for cloud backends with network latency.
    queue_config {
      capacity             = 2500
      max_shards           = 5
      min_shards           = 1
      max_samples_per_send = 1000
      batch_send_deadline  = "5s"
    }

    metadata_config {
      send = false
    }

    send_exemplars         = true
    send_native_histograms = false
  }
  external_labels = {
    env = "prod",
  }
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
  external_labels = {
    env = "prod",
  }
}
