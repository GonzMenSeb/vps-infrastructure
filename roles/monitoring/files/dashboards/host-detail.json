{
  "uid": "host-detail",
  "title": "Host detail",
  "tags": ["host", "vespiridion"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": {
          "query": "label_values(up{job=\"alloy\"}, host)",
          "refId": "StandardVariableQuery"
        },
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU modes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\",mode=\"idle\"}[5m]))",
          "legendFormat": "idle"
        },
        {
          "refId": "B",
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\",mode=\"user\"}[5m]))",
          "legendFormat": "user"
        },
        {
          "refId": "C",
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\",mode=\"system\"}[5m]))",
          "legendFormat": "system"
        },
        {
          "refId": "D",
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{host=\"$host\",mode=\"iowait\"}[5m]))",
          "legendFormat": "iowait"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory breakdown",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{host=\"$host\"} - node_memory_MemAvailable_bytes{host=\"$host\"} - node_memory_Cached_bytes{host=\"$host\"} - node_memory_Buffers_bytes{host=\"$host\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "node_memory_Cached_bytes{host=\"$host\"}",
          "legendFormat": "cached"
        },
        {
          "refId": "C",
          "expr": "node_memory_Buffers_bytes{host=\"$host\"}",
          "legendFormat": "buffers"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Disk I/O",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Disk I/O (bytes/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_disk_read_bytes_total{host=\"$host\"}[5m])",
          "legendFormat": "read {{device}}"
        },
        {
          "refId": "B",
          "expr": "rate(node_disk_written_bytes_total{host=\"$host\"}[5m])",
          "legendFormat": "write {{device}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Filesystem",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 31,
      "type": "table",
      "title": "Filesystem usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "options": {
        "sortBy": [{ "displayName": "mountpoint" }]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avail" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "size" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "used_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              }}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_avail_bytes{host=\"$host\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "instant": true,
          "legendFormat": "{{mountpoint}}"
        },
        {
          "refId": "B",
          "expr": "node_filesystem_size_bytes{host=\"$host\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "instant": true,
          "legendFormat": "{{mountpoint}}"
        },
        {
          "refId": "C",
          "expr": "100 * (1 - node_filesystem_avail_bytes{host=\"$host\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{host=\"$host\",fstype!~\"tmpfs|overlay|squashfs\"})",
          "instant": true,
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Network per device",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(node_network_receive_bytes_total{host=\"$host\",device!=\"lo\"}[5m])",
          "legendFormat": "rx {{device}}"
        },
        {
          "refId": "B",
          "expr": "rate(node_network_transmit_bytes_total{host=\"$host\",device!=\"lo\"}[5m])",
          "legendFormat": "tx {{device}}"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "System load",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "System load",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 46 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1{host=\"$host\"}",
          "legendFormat": "load1"
        },
        {
          "refId": "B",
          "expr": "node_load5{host=\"$host\"}",
          "legendFormat": "load5"
        },
        {
          "refId": "C",
          "expr": "node_load15{host=\"$host\"}",
          "legendFormat": "load15"
        }
      ]
    }
  ]
}
