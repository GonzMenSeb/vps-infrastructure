{
  "uid": "categorizer-health",
  "title": "Categorizer \u2014 Health",
  "tags": ["categorizer", "miplata", "ai"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Cascade throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tier hit rate (stacked)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "fillOpacity": 30,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tier) (rate(categorizer_predictions_total[5m]))",
          "legendFormat": "{{tier}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Reject rate (15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" },
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(categorizer_predictions_total{tier=\"reject\"}[15m])) / clamp_min(sum(rate(categorizer_predictions_total[15m])), 0.0001)",
          "legendFormat": "reject rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Total cascade latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(categorizer_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(categorizer_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(categorizer_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Per-tier latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(categorizer_tier_latency_seconds_bucket[5m])))",
          "legendFormat": "{{tier}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Embedding latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(categorizer_embedding_seconds_bucket[5m])))",
          "legendFormat": "embedding p95"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Corrections (user feedback, per hour)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(categorizer_corrections_total[1h]))",
          "legendFormat": "corrections/s"
        },
        {
          "refId": "B",
          "expr": "sum by (parent_was_correct) (rate(categorizer_corrections_total[1h]))",
          "legendFormat": "parent_was_correct={{parent_was_correct}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "llama-server",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "llama-server in-flight requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "llamacpp:requests_processing",
          "legendFormat": "processing"
        },
        {
          "refId": "B",
          "expr": "llamacpp:requests_deferred",
          "legendFormat": "deferred"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "llama-server throughput (tokens/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(llamacpp:prompt_tokens_total[5m])",
          "legendFormat": "prompt tok/s"
        },
        {
          "refId": "B",
          "expr": "rate(llamacpp:tokens_predicted_total[5m])",
          "legendFormat": "generated tok/s"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Scrape health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "id": 31,
      "type": "stat",
      "title": "categorizer-api up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"categorizer-api\"}",
          "instant": true
        }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "llama-server up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"llama-server\"}",
          "instant": true
        }
      ]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "categorizer /healthz probe",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{instance=\"categorizer-healthz\"}",
          "instant": true
        }
      ]
    },
    {
      "id": 34,
      "type": "stat",
      "title": "llama-server /health probe",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{instance=\"llama-server-health\"}",
          "instant": true
        }
      ]
    }
  ]
}
