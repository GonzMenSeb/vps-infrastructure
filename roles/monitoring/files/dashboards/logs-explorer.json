{
  "uid": "logs-explorer",
  "title": "Logs explorer",
  "tags": ["logs", "loki", "infra"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({host=~\".+\"}, compose_service)",
        "multi": false,
        "includeAll": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Volume",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log rate by host",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (host) (rate({host=~\".+\"}[1m]))",
          "queryType": "range",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log rate by service (top 10)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (compose_service) (rate({compose_service=~\".+\"}[1m])))",
          "queryType": "range",
          "legendFormat": "{{compose_service}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Errors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({host=~\".+\"} |~ \"(?i)(error|fatal|panic)\" [5m]))",
          "queryType": "range",
          "legendFormat": "errors/s"
        }
      ]
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Recent error lines",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 18, "x": 6, "y": 10 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "enableLogDetails": true
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{host=~\".+\"} |~ \"(?i)(error|fatal|panic)\" | json",
          "maxLines": 200
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Explore by service",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Logs for $service",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 23 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_service=\"$service\"}",
          "maxLines": 500
        }
      ]
    }
  ]
}
