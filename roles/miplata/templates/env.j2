DATABASE_URL=postgresql://{{ miplata_db_user }}:{{ vault_miplata_db_password }}@postgres:5432/{{ miplata_db_name }}
REDIS_URL=redis://redis:6379
JWT_SECRET={{ vault_miplata_jwt_secret }}
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY={{ vault_miplata_encryption_key }}
ADMIN_PASSWORD={{ vault_miplata_admin_password }}
PORT=3000
POSTGRES_USER={{ miplata_db_user }}
POSTGRES_PASSWORD={{ vault_miplata_db_password }}
POSTGRES_DB={{ miplata_db_name }}
CATEGORIZER_BASE_URL=https://{{ categorizer_host }}
CATEGORIZER_API_TOKEN={{ vault_categorizer_api_token }}

{% if enable_tracing %}
# OpenTelemetry — app-side instrumentation lives in the miplata repo
# (apps/api/src/tracing.ts bootstrap + --require CMD). These vars only take
# effect once that PR lands and the image is redeployed.
OTEL_SERVICE_NAME=miplata-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_RESOURCE_ATTRIBUTES=service.namespace=miplata,deployment.environment=prod
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_LOG_LEVEL=error
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
{% endif %}
