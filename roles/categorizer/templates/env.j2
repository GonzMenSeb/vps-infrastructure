# Postgres (self-hosted, dedicated to this service)
POSTGRES_USER={{ categorizer_db_user }}
POSTGRES_PASSWORD={{ vault_categorizer_db_password }}
POSTGRES_DB={{ categorizer_db_name }}
DATABASE_URL=postgresql+psycopg://{{ categorizer_db_user }}:{{ vault_categorizer_db_password }}@postgres:5432/{{ categorizer_db_name }}

# Read-only DSN into miplata's DB for querying user-labeled transactions as training data.
# Credentials come from the miplata role's RO user provisioning.
MIPLATA_RO_DATABASE_URL=postgresql+psycopg://{{ miplata_ro_user }}:{{ vault_miplata_ro_password | urlencode | regex_replace('/', '%2F') }}@miplata-postgres:5432/{{ miplata_db_name }}

# llama-server (internal, on categorizer_net).
LLM_BASE_URL=http://llama-server:8080/v1
LLM_MODEL={{ llm_inference_model_id }}

# Bearer token that clients must present on HTTP requests (used by Traefik middleware).
CATEGORIZER_API_TOKEN={{ vault_categorizer_api_token }}

# App config
CATEGORIZER_ENV=production
CATEGORIZER_PORT={{ categorizer_app_port }}
CATEGORIZER_THREADS={{ categorizer_app_threads }}
CATEGORIZER_LOG_LEVEL=INFO
# Confidence thresholds for the cascade. Tune over time against the gold set.
CATEGORIZER_RULE_MIN_CONFIDENCE=0.95
CATEGORIZER_KNN_MIN_CONFIDENCE=0.85
CATEGORIZER_KNN_MIN_MARGIN=0.05
CATEGORIZER_LLM_MIN_CONFIDENCE=0.70
CATEGORIZER_THINK_TRIGGER_CONFIDENCE=0.60

{% if enable_tracing %}
# OpenTelemetry — app-side instrumentation lives in the categorizer repo.
# These vars are consumed by opentelemetry-distro / instrumentation-fastapi.
# Alloy accepts OTLP/HTTP on :4318 on the observability network.
OTEL_SERVICE_NAME=categorizer-api
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_PYTHON_LOG_CORRELATION=true
{% endif %}
