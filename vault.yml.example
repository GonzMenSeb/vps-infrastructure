---
# Copy this to vault.yml and encrypt with: ansible-vault encrypt vault.yml
# Decrypt to edit: ansible-vault edit vault.yml

# DNS / PowerDNS
vault_pdns_db_root_password: "CHANGE_ME"
vault_pdns_db_password: "CHANGE_ME"
vault_pdns_admin_secret_key: "CHANGE_ME"
vault_pdns_api_key: "CHANGE_ME"

# Vaultwarden
vault_vaultwarden_admin_token: "CHANGE_ME"

# Grafana
vault_grafana_admin_password: "CHANGE_ME"

# Jenkins
vault_jenkins_admin_password: "CHANGE_ME"
vault_ansible_vault_password: "CHANGE_ME"
vault_jenkins_github_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (GitHub deploy key private key)
  -----END OPENSSH PRIVATE KEY-----
vault_jenkins_vps_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (VPS deploy key private key)
  -----END OPENSSH PRIVATE KEY-----
