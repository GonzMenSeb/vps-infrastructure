---
# Copy this to vault.yml and encrypt with: ansible-vault encrypt vault.yml
# Decrypt to edit: ansible-vault edit vault.yml

# DNS / PowerDNS
vault_pdns_db_root_password: "CHANGE_ME"
vault_pdns_db_password: "CHANGE_ME"
vault_pdns_admin_secret_key: "CHANGE_ME"
vault_pdns_api_key: "CHANGE_ME"

# Vaultwarden
vault_vaultwarden_admin_token: "CHANGE_ME"

# Grafana
vault_grafana_admin_password: "CHANGE_ME"

# Observability (Phase 1)
vault_observability_push_token: "CHANGE_ME_32_BYTE_HEX"
vault_grafana_oauth_client_id: "CHANGE_ME_GITHUB_OAUTH_CLIENT_ID"
vault_grafana_oauth_client_secret: "CHANGE_ME_GITHUB_OAUTH_CLIENT_SECRET"
vault_grafana_secret_key: "CHANGE_ME_32_BYTE_HEX"
# Alertmanager: leave empty to keep the default/null receiver only.
# Set to a Slack incoming-webhook URL to enable Slack routing for critical alerts.
vault_alertmanager_slack_webhook: ""

# Jenkins
vault_jenkins_admin_password: "CHANGE_ME"
vault_ansible_vault_password: "CHANGE_ME"
vault_jenkins_github_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (GitHub deploy key for vps-infrastructure)
  -----END OPENSSH PRIVATE KEY-----
vault_jenkins_miplata_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (GitHub deploy key for the miplata repo)
  -----END OPENSSH PRIVATE KEY-----
vault_jenkins_categorizer_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (GitHub deploy key for the miplata-categorizer repo)
  -----END OPENSSH PRIVATE KEY-----
vault_jenkins_vps_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  (VPS deploy key private key)
  -----END OPENSSH PRIVATE KEY-----

# Miplata
vault_miplata_db_password: "CHANGE_ME"
vault_miplata_jwt_secret: "CHANGE_ME"
vault_miplata_encryption_key: "CHANGE_ME_32_BYTE_HEX"
vault_miplata_admin_password: "CHANGE_ME"
vault_miplata_db_exporter_password: "CHANGE_ME_HEX"

# Zot registry
# vault_zot_registry_password: plaintext password for the `ci` user (Jenkins + VPS pull)
# vault_zot_htpasswd_hash: bcrypt hash of the above; generate with:
#     python3 -c "import bcrypt; print(bcrypt.hashpw(b'<password>', bcrypt.gensalt(rounds=10)).decode())"
vault_zot_registry_password: "CHANGE_ME"
vault_zot_htpasswd_hash: "CHANGE_ME_$2b$10$..."

# Metabase
vault_metabase_db_password: "CHANGE_ME"
vault_miplata_ro_password: "CHANGE_ME"
vault_metabase_admin_password: "CHANGE_ME"

# Categorizer (Colombian-Spanish tx categorization cascade)
vault_categorizer_db_password: "CHANGE_ME"
vault_categorizer_api_token: "CHANGE_ME_32_BYTE_HEX"  # used by Traefik bearer middleware

# Identifying info (hidden in encrypted vault instead of plaintext repo files)
vault_main_vps_ip: "CHANGE_ME"      # e.g. 203.0.113.10
vault_jenkins_vps_ip: "CHANGE_ME"   # e.g. 203.0.113.11
vault_domain: "CHANGE_ME"            # e.g. example.com
vault_acme_email: "CHANGE_ME"       # email used for Let's Encrypt registration
